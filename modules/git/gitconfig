[core]
    autocrlf = input
    editor = vim
    excludesfile = ~/.gitignore_global

[color]
    ui = auto

[push]
    default = current
    autoSetupRemote = true

[pull]
    rebase = true

[merge]
    conflictstyle = diff3

[diff]
    algorithm = patience

[alias]
    s  = status -s
    st = status
    co = checkout
    br = branch
    l  = log --oneline
    ll = log --color --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr)%C(bold blue)<%an>%Creset' --abbrev-commit
    unstage = reset HEAD --
    last = log -1 HEAD
    aliases = config --get-regexp alias

[init]
    defaultBranch = main

[include]
    # Local overrides (name, email, signing key) — not committed to repo
    path = ~/.gitconfig.local
