[core]
    autocrlf = input
    editor = vim
    excludesfile = ~/.gitignore_global

[color]
    ui = auto

[push]
    default = current
    autoSetupRemote = true

[pull]
    rebase = true

[merge]
    conflictstyle = diff3

[diff]
    algorithm = patience

[alias]
    s  = status -s
    st = status
    co = checkout
    br = branch
    l  = log --oneline
    ll = log --color --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr)%C(bold blue)<%an>%Creset' --abbrev-commit
    unstage = reset HEAD --
    last = log -1 HEAD
    aliases = config --get-regexp alias

    # Fork workflow helpers
    # Requires [github] user = YOUR_USERNAME in ~/.gitconfig.local
    #
    # git fork-init
    #   Renames origin → upstream, adds your fork as origin (SSH URL auto-composed)
    fork-init = "!f() { \
        gh_user=$(git config github.user); \
        if [ -z \"$gh_user\" ]; then \
            echo 'Error: github.user not set. Add to ~/.gitconfig.local:'; \
            echo '  [github]'; \
            echo '      user = YOUR_GITHUB_USERNAME'; \
            exit 1; \
        fi; \
        repo_name=$(basename $(git remote get-url origin) .git); \
        fork_url=\"git@github.com:$gh_user/$repo_name.git\"; \
        git remote rename origin upstream && \
        git remote add origin \"$fork_url\" && \
        git fetch origin && \
        printf '\nRemotes:\n' && \
        git remote -v; \
    }; f"

[init]
    defaultBranch = main

[include]
    # Local overrides (name, email, signing key) — not committed to repo
    path = ~/.gitconfig.local
